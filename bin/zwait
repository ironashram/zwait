#!/usr/bin/env bash
set -euo pipefail

SESSION="${ZELLIJ_SESSION:-zwait}"
TIMEOUT="${ZWAIT_TIMEOUT:-120}"
POLL="${ZWAIT_POLL:-1}"
PROMPT_PREFIX="${ZWAIT_PROMPT_PREFIX:-$ }"

[ $# -eq 0 ] && { echo "usage: zwait <command...>" >&2; exit 2; }

CURRENT="/tmp/zwait_${SESSION}_current"
DONE="/tmp/zwait_${SESSION}_done_$$"
LOCK="/tmp/zwait_${SESSION}_lock"
CMD="$*"
NLINES=$(printf '%s' "$CMD" | awk 'END{print NR}')
[ "$NLINES" -lt 1 ] && NLINES=1

have_settled() {
  awk -v p="$PROMPT_PREFIX" '
    BEGIN { plen = length(p) }
    { sub(/[[:space:]]+$/, "") }
    { if (substr($0, 1, plen) == p) last = NR }
    END { exit (last && last > 1) ? 0 : 1 }
  '
}

is_idle() {
  awk -v p="$PROMPT_PREFIX" '
    BEGIN { plen = length(p) }
    { lines[++n] = $0 }
    END {
      while (n > 0 && lines[n] ~ /^[[:space:]]*$/) n--
      if (n == 0) exit 1
      L = lines[n]
      if (substr(L, 1, plen) != p) exit 1
      rest = substr(L, plen + 1); gsub(/[[:space:]]/, "", rest)
      exit (rest == "") ? 0 : 1
    }
  '
}

extract_output() {
  awk -v nlines="$1" -v p="$PROMPT_PREFIX" '
    BEGIN { plen = length(p) }
    { sub(/[[:space:]]+$/, ""); lines[++n] = $0 }
    END {
      for (i = 1; i <= n; i++) {
        if (substr(lines[i], 1, plen) == p) prompts[++np] = i
      }
      if (np >= 2) {
        prev = prompts[np - 1]
        last = prompts[np]
        start = prev + 1 + nlines
        end   = last - 1
      } else if (np == 1) {
        start = 1
        end   = prompts[1] - 1
      } else {
        start = 1; end = n
      }
      while (start <= end && lines[start] == "") start++
      while (end   >= start && lines[end]   == "") end--
      for (i = start; i <= end; i++) print lines[i]
    }
  '
}

# Serialize concurrent zwait calls against the same session: they share one
# pane, so two writers would interleave keystrokes. The lock makes parallel
# calls run one-at-a-time (each to completion) instead of colliding.
exec 9>"$LOCK"
if ! flock -w "$TIMEOUT" 9; then
  echo "zwait: pane busy on $SESSION (lock held >${TIMEOUT}s); did not run" >&2
  exit 124
fi

# Don't type until the pane is back at an idle prompt. Guards the case where a
# previous call hit its timeout and exited (releasing the lock) while its
# command is still running in the pane.
guard=$((SECONDS + TIMEOUT))
until zellij -s "$SESSION" action dump-screen --full | is_idle; do
  if (( SECONDS >= guard )); then
    echo "zwait: pane busy on $SESSION (no idle prompt in ${TIMEOUT}s); did not run" >&2
    exit 124
  fi
  sleep "$POLL"
done

# Tell the precmd hook where to write this command's exit code, then send it.
rm -f "$DONE"
printf '%s' "$DONE" > "$CURRENT"

PASTE_START=$'\e[200~'
PASTE_END=$'\e[201~'
zellij -s "$SESSION" action write-chars "${PASTE_START}${CMD}${PASTE_END}"
zellij -s "$SESSION" action write 10

deadline=$((SECONDS + TIMEOUT))
while (( SECONDS < deadline )); do
  sleep "$POLL"
  [[ -s "$DONE" ]] || continue
  rc=$(cat "$DONE" 2>/dev/null || echo 0)
  for j in 0.05 0.1 0.2 0.4 0.8 1.6; do
    sleep "$j"
    screen=$(zellij -s "$SESSION" action dump-screen --full)
    if printf '%s\n' "$screen" | have_settled; then
      printf '%s\n' "$screen" | extract_output "$NLINES"
      rm -f "$DONE"
      exit "${rc:-0}"
    fi
  done
  printf '%s\n' "$screen" | extract_output "$NLINES"
  rm -f "$DONE"
  exit "${rc:-0}"
done
rm -f "$DONE"
echo "zwait: timeout after ${TIMEOUT}s waiting for command to finish" >&2
exit 124
