#!/usr/bin/env bash
set -euo pipefail

SESSION="${ZELLIJ_SESSION:-zwait}"
TIMEOUT="${ZWAIT_TIMEOUT:-120}"
POLL="${ZWAIT_POLL:-1}"

[ $# -eq 0 ] && { echo "usage: zwait <command...>" >&2; exit 2; }

BASE="/tmp/zwait_${SESSION}"
EXPECT="${BASE}_expect"
SEQF="${BASE}_seq"
LOCK="${BASE}_lock"
LOGF="${BASE}_log"
BUSY="${BASE}_busy"
CMD="$*"

# The pane shell must run under the zshell script(1) wrapper (zellij
# default_shell), which logs the pty byte stream to $LOGF. The shell hooks
# print invisible APC markers (ESC _ zwS<nonce> ESC \ ... ESC _ zwE<nonce>
# ESC \) around each claimed command, strictly ordered by the pty between the
# command echo and the next prompt, so the output is the exact byte range
# between them. No screen scraping, no prompt-pattern matching.
if [[ ! -f "$LOGF" ]]; then
  echo "zwait: no typescript log for $SESSION (pane not running under zshell); open a fresh pane" >&2
  exit 1
fi

# Render a raw typescript slice: strip OSC/APC/CSI escape sequences, emulate
# \r overwrites within each line, drop zsh's partial-line "%" marker when it
# is the final line, trim blank edge lines.
render() {
  sed -E $'s/\x1b\\][^\x07\x1b]*(\x07|\x1b\\\\)//g; s/\x1b_[^\x1b]*\x1b\\\\//g; s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x1b[=>]//g' |
  tr -d '\000' |
  awk '{
    sub(/\r+$/, "")
    n = split($0, a, "\r")
    buf = a[1]
    for (i = 2; i <= n; i++) {
      seg = a[i]
      if (seg ~ /^[[:space:]]*$/) continue
      buf = seg ((length(buf) > length(seg)) ? substr(buf, length(seg) + 1) : "")
    }
    sub(/[[:space:]]+$/, "", buf)
    out[++m] = buf
  }
  END {
    if (m && out[m] == "%") m--
    s = 1
    while (s <= m && out[s] == "") s++
    while (m >= s && out[m] == "") m--
    for (i = s; i <= m; i++) print out[i]
  }'
}

# Slice this command's output out of the typescript. $S0 (log size before the
# command was typed) bounds the search window. Returns 1 until the end marker
# has been flushed to the log.
log_extract() {
  local ms=$'\x1b_zwS'"${NONCE}"$'\x1b\\'
  local me=$'\x1b_zwE'"${NONCE}"$'\x1b\\'
  local scan so eo
  scan=$(dd if="$LOGF" iflag=skip_bytes skip="$S0" status=none 2>/dev/null |
    grep -F -abo -e "$ms" -e "$me" || true)
  so=$(printf '%s\n' "$scan" | awk -F: '/zwS/ {print $1; exit}')
  eo=$(printf '%s\n' "$scan" | awk -F: '/zwE/ {print $1; exit}')
  [[ -n $so && -n $eo ]] || return 1
  (( eo >= so + ${#ms} )) || return 1
  dd if="$LOGF" iflag=skip_bytes,count_bytes skip=$((S0 + so + ${#ms})) \
    count=$((eo - so - ${#ms})) status=none 2>/dev/null | render
}

# Serialize concurrent zwait calls against the same session: they share one
# pane, so two writers would interleave keystrokes. The lock makes parallel
# calls run one-at-a-time (each to completion) instead of colliding.
exec 9>"$LOCK"
if ! flock -w "$TIMEOUT" 9; then
  echo "zwait: pane busy on $SESSION (lock held >${TIMEOUT}s); did not run" >&2
  exit 124
fi

# Allocate a session-unique token under the lock (monotonic, never reused).
NONCE=$(( $(cat "$SEQF" 2>/dev/null || echo 0) + 1 ))
printf '%s' "$NONCE" > "$SEQF"
DONE="${BASE}_done_${NONCE}"
rm -f "$DONE"

# Don't type until the pane is idle: the busy flag is created by every
# preexec and removed by every precmd, so its absence means the shell is at a
# prompt. Guards the case where a previous call hit its timeout and exited
# (releasing the lock) while its command is still running in the pane.
guard=$((SECONDS + TIMEOUT))
while [[ -e "$BUSY" ]]; do
  if (( SECONDS >= guard )); then
    echo "zwait: pane busy on $SESSION (no idle prompt in ${TIMEOUT}s); did not run" >&2
    exit 124
  fi
  sleep "$POLL"
done
S0=$(stat -c%s "$LOGF")

# Hand the token to the shell, then send the command. The next real command
# (ours) claims the token via the preexec hook and writes its exit code into
# "$DONE". Empty Enters / redraws fire precmd but not preexec, so they can
# never claim the token or fake a completion.
printf '%s' "$NONCE" > "$EXPECT"

PASTE_START=$'\e[200~'
PASTE_END=$'\e[201~'
zellij -s "$SESSION" action write-chars "${PASTE_START}${CMD}${PASTE_END}"
zellij -s "$SESSION" action write 10

deadline=$((SECONDS + TIMEOUT))
while (( SECONDS < deadline )); do
  sleep "$POLL"
  [[ -s "$DONE" ]] || continue
  rc=$(cat "$DONE" 2>/dev/null || echo 0)
  for j in 0 0.05 0.1 0.2 0.4 0.8 1.6; do
    sleep "$j"
    if out=$(log_extract); then
      [[ -n "$out" ]] && printf '%s\n' "$out"
      rm -f "$DONE"
      exit "${rc:-0}"
    fi
  done
  echo "zwait: command finished (rc=$rc) but output markers never reached the log" >&2
  rm -f "$DONE"
  exit "${rc:-0}"
done
rm -f "$DONE"
echo "zwait: timeout after ${TIMEOUT}s waiting for command to finish" >&2
exit 124
